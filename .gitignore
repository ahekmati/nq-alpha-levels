# =============================================================================
# NQ Alpha Levels — .gitignore
# =============================================================================

# Credentials — NEVER commit
.env
*.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
*.txt

# =============================================================================
# ALL data/output files — these rebuild automatically, never commit
# =============================================================================

# All CSVs
*.csv

# All JSON outputs
*.json

# All model files
*.pkl
*.joblib
*.h5
*.pt
*.onnx

# Numba cache
__numba_cache__/
.numba_cache/

# =============================================================================
# Research output folders — results, not source
# =============================================================================
research_mnq_bear_model/
research_mnq_model_scan/
research_mnq_swing_meanrev/
research_mnq_swing_meanrev_recovery/
validation_run_441/
validation_run_441_v3/
validation_run_441_v4/
validation_variant8_deepcheck/
